# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Your production domain (e.g. https://courseshare.adefila.dev)
# Must also be set as Site URL in Supabase Auth > URL Configuration
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Resend — optional, enables report notification emails (https://resend.com)
RESEND_API_KEY=
